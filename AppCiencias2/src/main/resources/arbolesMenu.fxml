<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane fx:id="arbolesPane" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.ArbolesMenuController">
   <stylesheets>
      <URL value="@styles.css" />
   </stylesheets>
   <children>
      <HBox alignment="CENTER" prefHeight="600.0" prefWidth="1280.0">
         <children>

            <VBox alignment="CENTER" HBox.hgrow="ALWAYS">
               <children>
                  <ImageView fx:id="btnArbolSimple" accessibleRole="BUTTON" fitHeight="150.0" fitWidth="200.0" onMouseClicked="#abrirArbolSimple" pickOnBounds="true" preserveRatio="true">
                     <image>
                        <Image url="@icono-busquedas.png" />
                     </image>
                     <cursor>
                        <Cursor fx:constant="HAND" />
                     </cursor>
                  </ImageView>
                  <Label text="ÁRBOL SIMPLE">
                     <font>
                        <Font name="Myanmar Text Bold" size="24.0" />
                     </font>
                  </Label>
               </children>
               <cursor>
                  <Cursor fx:constant="DEFAULT" />
               </cursor>
            </VBox>

            <VBox alignment="CENTER" HBox.hgrow="ALWAYS">
               <children>
                  <ImageView fx:id="btnArbolOpcion2" accessibleRole="BUTTON" fitHeight="150.0" fitWidth="200.0" onMouseClicked="#abrirOpcion2" pickOnBounds="true" preserveRatio="true">
                     <image>
                        <Image url="@icono-busquedas.png" />
                     </image>
                     <cursor>
                        <Cursor fx:constant="HAND" />
                     </cursor>
                  </ImageView>
                  <Label text="ARBOL GENERADOR">
                     <font>
                        <Font name="Myanmar Text Bold" size="24.0" />
                     </font>
                  </Label>
               </children>
               <cursor>
                  <Cursor fx:constant="DEFAULT" />
               </cursor>
            </VBox>

            <VBox alignment="CENTER" HBox.hgrow="ALWAYS">
               <children>
                  <ImageView fx:id="btnArbolOpcion3" accessibleRole="BUTTON" fitHeight="150.0" fitWidth="200.0" onMouseClicked="#abrirOpcion3" pickOnBounds="true" preserveRatio="true">
                     <image>
                        <Image url="@icono-busquedas.png" />
                     </image>
                     <cursor>
                        <Cursor fx:constant="HAND" />
                     </cursor>
                  </ImageView>
                  <Label text="DISTANCIA ENTRE 2 ARBOLES">
                     <font>
                        <Font name="Myanmar Text Bold" size="24.0" />
                     </font>
                  </Label>
               </children>
               <cursor>
                  <Cursor fx:constant="DEFAULT" />
               </cursor>
            </VBox>

         </children>
         <opaqueInsets>
            <Insets left="40.0" />
         </opaqueInsets>
      </HBox>
   </children>
</AnchorPane>