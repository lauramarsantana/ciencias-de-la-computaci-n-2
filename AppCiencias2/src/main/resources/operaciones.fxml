<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.OperacionesGrafosController">
    <stylesheets>
        <URL value="@styles.css" />
    </stylesheets>
    <children>
      <VBox prefHeight="650.0" prefWidth="1280.0" style="-fx-background-color: white;">
         <children>
            <HBox alignment="CENTER" prefHeight="50.0">
               <children>
                  <Label text="Número de vértices G2:" HBox.hgrow="ALWAYS" />
                  <TextField fx:id="verticesG1" promptText="ej: 3">
                     <HBox.margin>
                        <Insets left="10.0" />
                     </HBox.margin>
                  </TextField>
                  <Button mnemonicParsing="false" onMouseClicked="#dibujarG1" text="Ver G1">
                     <HBox.margin>
                        <Insets left="40.0" />
                     </HBox.margin>
                  </Button>
               </children>
            </HBox>
            <HBox alignment="CENTER" prefHeight="50.0">
               <children>
                  <Label text="Número de vértices G2:" HBox.hgrow="ALWAYS" />
                  <TextField fx:id="verticesG2" promptText="ej: 5">
                     <HBox.margin>
                        <Insets left="10.0" />
                     </HBox.margin>
                  </TextField>
                  <Button mnemonicParsing="false" onMouseClicked="#dibujarG2" text="Ver G2">
                     <HBox.margin>
                        <Insets left="40.0" />
                     </HBox.margin>
                  </Button>
               </children>
            </HBox>
            <HBox alignment="CENTER" prefHeight="50.0">
               <children>
                  <Label text="Operación:">
                     <HBox.margin>
                        <Insets left="30.0" right="10.0" />
                     </HBox.margin>
                  </Label>
                  <ComboBox fx:id="operacion" prefWidth="100.0" />
                  <Button mnemonicParsing="false" onMouseClicked="#hacerOperacion" text="Ver resultado de operación">
                     <HBox.margin>
                        <Insets left="40.0" />
                     </HBox.margin>
                  </Button>
                  <Button mnemonicParsing="false" onMouseClicked="#handleGuardar" text="Guardar">
                     <HBox.margin>
                        <Insets left="40.0" />
                     </HBox.margin>
                  </Button>
                  <Button mnemonicParsing="false" onMouseClicked="#handleCargar" text="Cargar">
                     <HBox.margin>
                        <Insets left="40.0" />
                     </HBox.margin>
                  </Button>
                  <Button mnemonicParsing="false" onMouseClicked="#handleLimpiar" text="Limpiar">
                     <HBox.margin>
                        <Insets left="40.0" />
                     </HBox.margin>
                  </Button>
               </children>
            </HBox>
            <HBox prefHeight="332.0" VBox.vgrow="ALWAYS">
               <children>
                  <VBox alignment="TOP_CENTER" HBox.hgrow="ALWAYS">
                     <children>
                        <Label fx:id="infoG1" text="Label" />
                        <Pane fx:id="paneG1" prefWidth="406.0" style="-fx-border-color: blue; -fx-border-radius: 10px; -fx-background-color: white;" VBox.vgrow="ALWAYS" />
                     </children>
                     <HBox.margin>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                     </HBox.margin>
                  </VBox>
                  <VBox alignment="TOP_CENTER" HBox.hgrow="ALWAYS">
                     <children>
                        <Label fx:id="infoG2" text="Label" />
                        <Pane fx:id="paneG2" prefWidth="406.0" style="-fx-border-color: blue; -fx-border-radius: 10px; -fx-background-color: white;" VBox.vgrow="ALWAYS" />
                     </children>
                     <HBox.margin>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                     </HBox.margin>
                  </VBox>
                  <VBox alignment="TOP_CENTER" HBox.hgrow="ALWAYS">
                     <children>
                        <Label fx:id="infoG3" text="Label" />
                        <Pane fx:id="paneG3" prefWidth="406.0" style="-fx-background-color: white; -fx-border-color: blue; -fx-border-radius: 10px;" VBox.vgrow="ALWAYS" />
                     </children>
                     <HBox.margin>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                     </HBox.margin>
                  </VBox>
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
