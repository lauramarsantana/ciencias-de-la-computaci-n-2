<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.OperacionesGrafosController">
    <stylesheets>
        <URL value="@styles.css" />
    </stylesheets>
    <children>
      <VBox prefHeight="600.0" prefWidth="1280.0" style="-fx-background-color: white;">
         <children>
            <HBox alignment="CENTER" prefHeight="50.0">
               <children>
                  <Label text="G1 vertices:" HBox.hgrow="ALWAYS" />
                  <TextField fx:id="verticesG1" promptText="ej: A,B,C">
                     <HBox.margin>
                        <Insets left="10.0" />
                     </HBox.margin>
                  </TextField>
                  <Label text="G1 Aristas:">
                     <HBox.margin>
                        <Insets left="40.0" right="10.0" />
                     </HBox.margin>
                  </Label>
                  <TextField fx:id="aristasG1" promptText="ej: A-C,D-B">
                     <HBox.margin>
                        <Insets />
                     </HBox.margin>
                  </TextField>
                  <Button mnemonicParsing="false" onMouseClicked="#dibujarG1" text="Ver G1">
                     <HBox.margin>
                        <Insets left="40.0" />
                     </HBox.margin>
                  </Button>
               </children>
            </HBox>
            <HBox alignment="CENTER" prefHeight="50.0">
               <children>
                  <Label text="G2 vertices:" HBox.hgrow="ALWAYS" />
                  <TextField fx:id="verticesG2" promptText="ej: A,B,C">
                     <HBox.margin>
                        <Insets left="10.0" />
                     </HBox.margin>
                  </TextField>
                  <Label text="G2 Aristas:">
                     <HBox.margin>
                        <Insets left="40.0" right="10.0" />
                     </HBox.margin>
                  </Label>
                  <TextField fx:id="aristasG2" promptText="ej: A-B,C-D">
                     <HBox.margin>
                        <Insets />
                     </HBox.margin>
                  </TextField>
                  <Button mnemonicParsing="false" onMouseClicked="#dibujarG2" text="Ver G2">
                     <HBox.margin>
                        <Insets left="40.0" />
                     </HBox.margin>
                  </Button>
               </children>
            </HBox>
            <HBox alignment="CENTER" prefHeight="50.0">
               <children>
                  <Label text="Operación:">
                     <HBox.margin>
                        <Insets left="30.0" right="10.0" />
                     </HBox.margin>
                  </Label>
                  <ComboBox fx:id="operacion" prefWidth="100.0" />
                  <Button mnemonicParsing="false" onMouseClicked="#hacerOperacion" text="Ver resultado de operación">
                     <HBox.margin>
                        <Insets left="40.0" />
                     </HBox.margin>
                  </Button>
               </children>
            </HBox>
            <HBox prefHeight="332.0" VBox.vgrow="ALWAYS">
               <children>
                  <Pane fx:id="paneG1" prefWidth="420.0" style="-fx-border-color: blue; -fx-border-radius: 10px; -fx-background-color: white;" HBox.hgrow="ALWAYS">
                     <HBox.margin>
                        <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
                     </HBox.margin>
                  </Pane>
                  <Pane fx:id="paneG2" prefWidth="420.0" style="-fx-border-color: blue; -fx-border-radius: 10px; -fx-background-color: white;" HBox.hgrow="ALWAYS">
                     <HBox.margin>
                        <Insets bottom="5.0" top="5.0" />
                     </HBox.margin></Pane>
                  <Pane fx:id="paneG3" prefWidth="420.0" style="-fx-background-color: white; -fx-border-color: blue; -fx-border-radius: 10px;" HBox.hgrow="ALWAYS">
                     <HBox.margin>
                        <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
                     </HBox.margin>
                  </Pane>
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
