<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane fx:id="triePane" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.TriesResiduosController">

    <stylesheets>
        <URL value="@/styles.css" />
    </stylesheets>
    <children>
        <VBox alignment="CENTER" prefHeight="600.0" prefWidth="1280.0" spacing="12">
            <padding>
                <Insets bottom="20" left="20" right="20" top="20" />
            </padding>

                  <!-- Entrada de mensaje -->
            <HBox alignment="CENTER" spacing="10">
                <Label text="Mensaje:" />
                <TextField fx:id="mensajeField" promptText="Ej: MURCIELAGO" />
                <Button onAction="#procesarMensaje" text="Procesar" />
                <Button onAction="#initializeTree" text="Reiniciar" />
            </HBox>

                  <!-- Buscar letra -->
            <HBox alignment="CENTER" spacing="10">
                <Label text="Buscar letra:" />
                <TextField fx:id="buscarField" promptText="Ej: A" />
                <Button onAction="#buscarClave" text="Buscar" />
                <Button onAction="#clearSearch" text="Limpiar búsqueda" />
            </HBox>

                  <!-- Tabla de códigos binarios -->
            <TableView fx:id="tablaCodigos" maxWidth="400.0" prefHeight="300.0" prefWidth="400.0" style="-fx-background-radius: 5; -fx-border-radius: 5;">
                <columns>
                    <TableColumn fx:id="colLetra" prefWidth="80.0" text="Letra" />
                    <TableColumn fx:id="colAlfabeto" prefWidth="120.0" text="Alfabeto (A=1)" />
                    <TableColumn fx:id="colBinario" prefWidth="180.0" text="Código Binario" />
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                </columnResizePolicy>
            </TableView>

                  <!-- Resultado -->
            <Label fx:id="resultadoLabel" style="-fx-font-size: 14px; -fx-text-fill: #2262C6;" text="Listo." />

                  <!-- Visualización del trie -->
            <Pane fx:id="arbolPane" prefHeight="500" prefWidth="1000" style="-fx-background-color: #f4f4f4;" />
        </VBox>
    </children>
</AnchorPane>
