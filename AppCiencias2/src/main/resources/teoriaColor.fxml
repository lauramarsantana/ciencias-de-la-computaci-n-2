<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.TeoriaColorController">
   <stylesheets>
      <URL value="@styles.css" />
   </stylesheets>
   <children>
      <VBox prefHeight="650.0" prefWidth="1280.0" style="-fx-background-color: white;">
         <children>
            <HBox alignment="CENTER" prefHeight="50.0">
               <children>
                  <Label text="G1 vertices:" HBox.hgrow="ALWAYS" />
                  <TextField fx:id="verticesG1" promptText="ej: A,B,C">
                     <HBox.margin>
                        <Insets left="10.0" />
                     </HBox.margin>
                  </TextField>
                  <Button mnemonicParsing="false" onMouseClicked="#dibujarG1" text="Ver G1">
                     <HBox.margin>
                        <Insets left="40.0" />
                     </HBox.margin>
                  </Button>
               </children>
            </HBox>
             <HBox alignment="CENTER" prefHeight="50.0">
                 <children>
                     <Label text="Elemento:">
                         <HBox.margin>
                             <Insets left="20.0" right="5.0" />
                         </HBox.margin>
                     </Label>
                     <ComboBox fx:id="comboElemento" onAction="#cambiarCategoria" prefWidth="110.0" />

                     <Label text="Operación:">
                         <HBox.margin>
                             <Insets left="20.0" right="5.0" />
                         </HBox.margin>
                     </Label>
                     <ComboBox fx:id="operacion" prefWidth="220.0" />

                     <Button mnemonicParsing="false" onMouseClicked="#hacerOperacion" text="Ver resultado de operación">
                         <HBox.margin>
                             <Insets left="30.0" />
                         </HBox.margin>
                     </Button>
                     <Button mnemonicParsing="false" onMouseClicked="#handleGuardar" text="Guardar">
                         <HBox.margin>
                             <Insets left="20.0" />
                         </HBox.margin>
                     </Button>
                     <Button mnemonicParsing="false" onMouseClicked="#handleCargar" text="Cargar">
                         <HBox.margin>
                             <Insets left="20.0" />
                         </HBox.margin>
                     </Button>
                     <Button mnemonicParsing="false" onMouseClicked="#handleLimpiar" text="Limpiar">
                         <HBox.margin>
                             <Insets left="20.0" />
                         </HBox.margin>
                     </Button>
                 </children>
             </HBox>
            <HBox prefHeight="332.0" VBox.vgrow="ALWAYS">
               <children>
                  <VBox alignment="TOP_CENTER" HBox.hgrow="ALWAYS">
                     <children>
                        <Pane fx:id="paneG1" prefWidth="406.0" style="-fx-border-color: blue; -fx-border-radius: 10px; -fx-background-color: white;" VBox.vgrow="ALWAYS" />
                     </children>
                     <HBox.margin>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                     </HBox.margin>
                  </VBox>
                   <VBox alignment="TOP_CENTER" HBox.hgrow="ALWAYS">
                       <children>
                           <ScrollPane fitToWidth="true" style="-fx-background-color: white; -fx-border-color: blue; -fx-border-radius: 10px;" VBox.vgrow="ALWAYS">
                               <content>
                                   <Label fx:id="infoG3" style="-fx-padding: 10;" text="Esperando análisis..." wrapText="true" />
                               </content>
                           </ScrollPane>
                       </children>
                       <HBox.margin>
                           <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                       </HBox.margin>
                   </VBox>
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
