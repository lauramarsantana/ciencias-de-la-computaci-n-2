<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane fx:id="internasPane" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.BusquedasInternasController">
   <stylesheets>
      <URL value="@styles.css" />
   </stylesheets>
   <children>
      <HBox alignment="CENTER" prefHeight="600.0" prefWidth="1280.0">
         <children>
            <VBox alignment="CENTER" HBox.hgrow="ALWAYS">
               <children>
                  <ImageView fx:id="btnGrafos11" accessibleRole="BUTTON" fitHeight="150.0" fitWidth="200.0" onMouseClicked="#openLineal" pickOnBounds="true" preserveRatio="true">
                     <image>
                        <Image url="@icono-b.i.lineal.png" />
                     </image>
                     <cursor>
                        <Cursor fx:constant="HAND" />
                     </cursor>
                  </ImageView>
                  <Label text="LINEAL">
                     <font>
                        <Font name="Myanmar Text Bold" size="24.0" />
                     </font>
                  </Label>
               </children>
               <cursor>
                  <Cursor fx:constant="DEFAULT" />
               </cursor>
            </VBox>
            <VBox alignment="CENTER" HBox.hgrow="ALWAYS">
               <children>
                  <ImageView fx:id="btnBusquedas1" accessibleRole="BUTTON" fitHeight="150.0" fitWidth="200.0" onMouseClicked="#openBinario" pickOnBounds="true" preserveRatio="true">
                     <image>
                        <Image url="@icono-b.i.binario.png" />
                     </image>
                     <cursor>
                        <Cursor fx:constant="HAND" />
                     </cursor>
                  </ImageView>
                  <Label text="BINARIO" textFill="#000204">
                     <font>
                        <Font name="Myanmar Text Bold" size="24.0" />
                     </font>
                  </Label>
               </children>
               <cursor>
                  <Cursor fx:constant="DEFAULT" />
               </cursor>
            </VBox>
            <VBox alignment="CENTER" HBox.hgrow="ALWAYS">
               <children>
                  <ImageView fx:id="btnGrafos111" accessibleRole="BUTTON" fitHeight="150.0" fitWidth="200.0" onMouseClicked="#openFuncionHash" pickOnBounds="true" preserveRatio="true">
                     <image>
                        <Image url="@icono-b.i.funcionHash.png" />
                     </image>
                     <cursor>
                        <Cursor fx:constant="HAND" />
                     </cursor>
                  </ImageView>
                  <Label text="FUNCIÓN HASH">
                     <font>
                        <Font name="Myanmar Text Bold" size="24.0" />
                     </font>
                  </Label>
               </children>
            </VBox>
            <VBox alignment="CENTER" HBox.hgrow="ALWAYS">
               <children>
                  <ImageView fx:id="btnGrafos1" accessibleRole="BUTTON" fitHeight="150.0" fitWidth="200.0" onMouseClicked="#openBResiduos" pickOnBounds="true" preserveRatio="true">
                     <image>
                        <Image url="@icono-B.porResiduos.png" />
                     </image>
                     <cursor>
                        <Cursor fx:constant="HAND" />
                     </cursor>
                  </ImageView>
                  <Label text="BUSQUEDA POR ÁRBOLES">
                     <font>
                        <Font name="Myanmar Text Bold" size="24.0" />
                     </font>
                  </Label>
               </children>
               <cursor>
                  <Cursor fx:constant="DEFAULT" />
               </cursor>
            </VBox>
         </children>
         <opaqueInsets>
            <Insets left="40.0" />
         </opaqueInsets>
      </HBox>
   </children>
</AnchorPane>
