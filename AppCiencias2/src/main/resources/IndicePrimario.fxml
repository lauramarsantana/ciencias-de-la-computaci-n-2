<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane fx:id="indicePane" prefHeight="700.0" prefWidth="1280.0"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.IndicePrimarioController">

    <stylesheets>
        <URL value="@/styles.css" />
    </stylesheets>

    <children>
        <VBox alignment="TOP_CENTER" prefHeight="700.0" prefWidth="1280.0"
              spacing="14" style="-fx-background-color: #fff;">
            <padding>
                <Insets top="16" right="16" bottom="16" left="16"/>
            </padding>

            <children>

                <!-- Configuración -->
                <HBox alignment="CENTER" spacing="10">
                    <children>
                        <Label text="Registros (r):" />
                        <TextField fx:id="registrosField" prefWidth="80" promptText="30000"/>

                        <Label text="Bloque (B):" />
                        <TextField fx:id="bloqueField" prefWidth="80" promptText="1024"/>

                        <Label text="Registro dato (R):" />
                        <TextField fx:id="registroDatoField" prefWidth="80" promptText="100"/>

                        <Label text="Registro índice (Ri):" />
                        <TextField fx:id="registroIndiceField" prefWidth="80" promptText="15"/>

                        <Button text="Crear estructura" onAction="#crearEstructura"/>
                    </children>
                </HBox>

                <!-- Resultados -->
                <VBox alignment="CENTER_LEFT" spacing="6"
                      style="-fx-border-color: #0e2ebe; -fx-border-width: 1; -fx-padding: 10; -fx-background-color: #f8faff;">
                    <children>
                        <Label fx:id="bfrLabel" text="bfr = " />
                        <Label fx:id="bLabel" text="b = " />
                        <Label fx:id="comparacionesLabel" text="b/2 = " />
                        <Label fx:id="logDatosLabel" text="Accesos búsqueda binaria datos = " />
                        <Label fx:id="bfriLabel" text="bfri = " />
                        <Label fx:id="biLabel" text="bi = " />
                        <Label fx:id="logIndiceLabel" text="Accesos con índice primario = " />
                    </children>
                </VBox>
                
                <HBox alignment="CENTER">
                    <children>
                        <Label 
                            text="Cada bloque índice referencia un grupo de bloques de datos consecutivos. La vista muestra el primer bloque, uno intermedio y el último."
                            wrapText="true"
                            prefWidth="900"
                            maxWidth="900"
                            style="-fx-font-size: 14px; -fx-text-fill: #333333;" />
                    </children>
                </HBox>

                <!-- Estructura visual -->
                <HBox alignment="TOP_CENTER" spacing="30">

                    <children>
                        <!-- Cuadro izquierdo: índice -->
                        <VBox spacing="8" alignment="TOP_CENTER">
                            <children>
                                <Label text="ÍNDICE PRIMARIO" style="-fx-font-weight: bold; -fx-font-size: 16px;" />
                                <ScrollPane fitToWidth="true" prefHeight="400" prefWidth="220">
                                    <content>
                                        <VBox fx:id="indiceBox" spacing="2" style="-fx-padding: 8; -fx-border-color: black; -fx-border-width: 1;" />
                                    </content>
                                </ScrollPane>
                            </children>
                        </VBox>

                        <!-- Cuadro derecho: datos -->
                        <VBox spacing="8" alignment="TOP_CENTER">
                            <children>
                                <Label text="BLOQUES DE DATOS" style="-fx-font-weight: bold; -fx-font-size: 16px;" />
                                <ScrollPane fitToWidth="true" prefHeight="400" prefWidth="320">
                                    <content>
                                        <VBox fx:id="datosBox" spacing="2" style="-fx-padding: 8; -fx-border-color: black; -fx-border-width: 1;" />
                                    </content>
                                </ScrollPane>
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <!-- Botones -->
                <HBox alignment="CENTER" spacing="20">
                    <children>
                        <Button text="Limpiar" onAction="#limpiarEstructura"/>
                        <Button text="Guardar Estructura" onAction="#guardarEstructura"/>
                        <Button text="Recuperar Estructura" onAction="#cargarEstructura"/>
                    </children>
                </HBox>

                <!-- Resultado -->
                <Label fx:id="resultadoLabel" alignment="CENTER"
                       style="-fx-font-size: 14px;" text="Listo."
                       textAlignment="CENTER" textFill="#0e2ebe">
                    <font>
                        <Font name="Myanmar Text Bold" size="22.0" />
                    </font>
                </Label>

            </children>
        </VBox>
    </children>
</AnchorPane>