<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="1280.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.IndiceSecundarioController">

    <stylesheets>
        <URL value="@/styles.css" />
    </stylesheets>

    <children>
        <VBox alignment="TOP_CENTER" prefHeight="600.0" prefWidth="1280.0" spacing="14" style="-fx-background-color: #fff;">
            <padding>
                <Insets bottom="16" left="16" right="16" top="16" />
            </padding>

            <children>

                <HBox alignment="CENTER" spacing="10">
                    <children>
                        <Label text="Registros (r):" />
                        <TextField fx:id="registrosField" prefWidth="80" promptText="30000" />

                        <Label text="Bloque (B):" />
                        <TextField fx:id="bloqueField" prefWidth="80" promptText="1024" />

                        <Label text="Registro dato (R):" />
                        <TextField fx:id="registroDatoField" prefWidth="80" promptText="100" />

                        <Label text="Registro índice (Ri):" />
                        <TextField fx:id="registroIndiceField" prefWidth="80" promptText="15" />

                        <Button onAction="#crearEstructura" text="Crear estructura" />
                    </children>
                </HBox>

                <VBox spacing="6" style="-fx-border-color: #0e2ebe; -fx-border-width: 1; -fx-padding: 10; -fx-background-color: #f8faff;">
                    <children>
                        <Label fx:id="bfrLabel" text="Registros por bloque de datos (bfr) = " />
                        <Label fx:id="bLabel" text="Bloques para datos (b) = " />
                        <Label fx:id="bfriLabel" text="Registros índice por bloque (bfri) = " />
                        <Label fx:id="biLabel" text="Bloques por registros índice (bi) = " />
                        <Label fx:id="accesosLabel" text="Accesos con índice secundario = " />
                    </children>
                </VBox>

                <HBox alignment="CENTER">
                    <children>
                        <Label fx:id="explicacionLabel" maxWidth="760" prefWidth="760" style="-fx-font-size: 14px; -fx-text-fill: #333333;" wrapText="true" />
                    </children>
                </HBox>

                <HBox alignment="TOP_CENTER" spacing="30">
                    <children>

                        <VBox alignment="TOP_CENTER" spacing="8">
                            <children>
                                <Label style="-fx-font-weight: bold; -fx-font-size: 16px;" text="ÍNDICE SECUNDARIO" />
                                <VBox fx:id="indiceBox" prefHeight="250" prefWidth="320" spacing="8" style="-fx-border-color: black; -fx-padding: 8;" />
                            </children>
                        </VBox>

                        <VBox alignment="TOP_CENTER" spacing="8">
                            <children>
                                <Label style="-fx-font-weight: bold; -fx-font-size: 16px;" text="ESTRUCTURA PRINCIPAL DE DATOS" />
                                <VBox fx:id="datosBox" prefHeight="250" prefWidth="320" spacing="8" style="-fx-border-color: black; -fx-padding: 8;" />
                            </children>
                        </VBox>

                    </children>
                </HBox>

                <HBox alignment="CENTER" spacing="20">
                    <children>
                        <Button onAction="#limpiarEstructura" text="Limpiar" />
                        <Button onAction="#guardarEstructura" text="Guardar Estructura" />
                        <Button onAction="#cargarEstructura" text="Recuperar Estructura" />
                    </children>
                </HBox>

                <Label fx:id="resultadoLabel" text="Listo." textFill="#0e2ebe">
                    <font>
                        <Font name="Myanmar Text Bold" size="20.0" />
                    </font>
                </Label>

            </children>
        </VBox>
    </children>
</AnchorPane>
