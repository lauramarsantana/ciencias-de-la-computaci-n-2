<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="1280.0" style="-fx-background-color: #f4f4f4;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.ResiduosMultiplesController">
    <stylesheets>
        <URL value="@/styles.css" />
    </stylesheets>
    <children>
      <VBox>
         <children>
            <HBox alignment="CENTER" prefHeight="227.0" prefWidth="1280.0" style="-fx-background-color: white;">
               <children>
                    <VBox alignment="TOP_CENTER" spacing="15.0" HBox.hgrow="ALWAYS">
                        <padding>
                            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                        </padding>
                        <children>
                            <Label style="-fx-font-weight: bold; -fx-text-fill: #2262C6;" text="🔧 Configuración del Árbol">
                                <font>
                                    <Font name="System Bold" size="24.0" />
                                </font>
                            </Label>
                            <Label style="-fx-font-style: italic; -fx-text-fill: #555;" text="Desliza para elegir cuántos bits procesar por nivel (m)" />
                            <VBox alignment="CENTER" spacing="5.0">
                                  <children>
                                      <Label fx:id="labelM" text="m = 2 (M = 4 hijos)" textFill="#2262c6">
                                          <font>
                                              <Font name="System Bold" size="14.0" />
                                          </font>
                                      </Label>
                                      <Slider fx:id="sliderM" blockIncrement="1.0" majorTickUnit="1.0" max="4.0" min="1.0" minorTickCount="0" prefWidth="200.0" showTickLabels="true" showTickMarks="true" snapToTicks="true" value="2.0">
                                          <cursor>
                                              <Cursor fx:constant="HAND" />
                                          </cursor>
                                      </Slider>
                                  </children>
                              </VBox>
            
                            <HBox alignment="CENTER" spacing="10.0" VBox.vgrow="ALWAYS">
                                <children>
                                    <TextField fx:id="mensajeField" prefWidth="300.0" promptText="Escribe un mensaje (ej: MURCIELAGO)" style="-fx-background-radius: 5;" />
                                    <Button mnemonicParsing="false" onAction="#procesarMensaje" style="-fx-background-color: #2262c6; -fx-background-radius: 5;" text="Generar Árbol" textFill="WHITE">
                                        <font>
                                            <Font name="System Bold" size="12.0" />
                                        </font>
                                        <cursor>
                                            <Cursor fx:constant="HAND" />
                                        </cursor>
                                    </Button>
                                </children>
                            </HBox>
            
                            <Label fx:id="resultadoLabel" text="Ajusta 'm' y escribe un mensaje para empezar." textFill="#555555" VBox.vgrow="ALWAYS" />
                        </children>
                    </VBox>
                  <VBox prefHeight="200.0" prefWidth="100.0" HBox.hgrow="ALWAYS">
                     <children>
                        <TableView fx:id="tablaCodigos" maxWidth="400.0" prefHeight="300.0" prefWidth="400.0" style="-fx-background-radius: 5; -fx-border-radius: 5;" VBox.vgrow="ALWAYS">
                           <columns>
                              <TableColumn fx:id="colLetra" prefWidth="80.0" text="Letra" />
                              <TableColumn fx:id="colAlfabeto" prefWidth="120.0" text="Alfabeto (A=1)" />
                              <TableColumn fx:id="colBinario" prefWidth="180.0" text="Código Binario" />
                           </columns>
                           <columnResizePolicy>
                              <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                           </columnResizePolicy>
                        </TableView>
                     </children>
                     <padding>
                        <Insets top="10.0" />
                     </padding>
                  </VBox>
               </children>
            </HBox>
             <ScrollPane fx:id="scrollPaneArbol" fitToHeight="true" fitToWidth="true" pannable="true">
                 <content>
                     <Pane fx:id="arbolPane" prefHeight="375.0" prefWidth="1277.0" style="-fx-background-color: white;" />
                 </content>
             </ScrollPane>
         </children>
      </VBox>
    </children>
</AnchorPane>
