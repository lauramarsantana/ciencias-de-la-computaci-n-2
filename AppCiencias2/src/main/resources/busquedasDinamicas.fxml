<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane fx:id="dinamicasPane" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.BusquedasDinamicasController">

    <stylesheets>
        <URL value="@styles.css" />
    </stylesheets>

    <children>
          <HBox alignment="CENTER" prefHeight="600.0" prefWidth="1280.0">
              <children>
                  <VBox alignment="CENTER" HBox.hgrow="ALWAYS">
                      <children>
                          <ImageView fx:id="btnExpTotales" accessibleRole="BUTTON" fitHeight="150.0" fitWidth="200.0" onMouseClicked="#openExpTotales" pickOnBounds="true" preserveRatio="true">
                              <image>
                                  <Image url="@icono-b.externas.png" />
                              </image>
                              <cursor>
                                  <Cursor fx:constant="HAND" />
                              </cursor>
                          </ImageView>
                          <Label text="EXP. TOTALES">
                              <font>
                                  <Font name="Myanmar Text Bold" size="24.0" />
                              </font>
                          </Label>
                      </children>
                  </VBox>

                  <VBox alignment="CENTER" HBox.hgrow="ALWAYS">
                      <children>
                          <ImageView fx:id="btnExpParciales" accessibleRole="BUTTON" fitHeight="150.0" fitWidth="200.0" onMouseClicked="#openExpParciales" pickOnBounds="true" preserveRatio="true">
                              <image>
                                  <Image url="@icono-b.externas.png" />
                              </image>
                              <cursor>
                                  <Cursor fx:constant="HAND" />
                              </cursor>
                          </ImageView>
                          <Label text="EXP. PARCIALES">
                              <font>
                                  <Font name="Myanmar Text Bold" size="24.0" />
                              </font>
                          </Label>
                      </children>
                  </VBox>
              </children>
          </HBox>
    </children>
</AnchorPane>
