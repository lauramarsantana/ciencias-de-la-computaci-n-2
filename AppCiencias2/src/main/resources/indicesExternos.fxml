<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane fx:id="indicesPane" prefHeight="450.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.IndicesExternosController">

   <stylesheets>
      <URL value="@/styles.css" />
   </stylesheets>

   <children>
      <HBox prefHeight="600.0" prefWidth="1280.0">
         <children>

            <VBox alignment="CENTER" HBox.hgrow="ALWAYS">
               <children>
                  <ImageView fx:id="btnIndicePrimario" accessibleRole="BUTTON" fitHeight="120.0" fitWidth="140.0" onMouseClicked="#openIndicePrimario" pickOnBounds="true" preserveRatio="true">
                     <image>
                        <Image url="@/icono-b.externas.png" />
                     </image>
                     <cursor>
                        <Cursor fx:constant="HAND" />
                     </cursor>
                  </ImageView>
                  <Label text="PRIMARIO">
                     <font>
                        <Font name="Myanmar Text Bold" size="18.0" />
                     </font>
                  </Label>
               </children>
            </VBox>

            <VBox alignment="CENTER" HBox.hgrow="ALWAYS">
               <children>
                  <ImageView fx:id="btnIndiceSecundario" accessibleRole="BUTTON" fitHeight="120.0" fitWidth="140.0" onMouseClicked="#openIndiceSecundario" pickOnBounds="true" preserveRatio="true">
                     <image>
                        <Image url="@/icono-b.externas.png" />
                     </image>
                     <cursor>
                        <Cursor fx:constant="HAND" />
                     </cursor>
                  </ImageView>
                  <Label text="SECUNDARIO">
                     <font>
                        <Font name="Myanmar Text Bold" size="18.0" />
                     </font>
                  </Label>
               </children>
            </VBox>

            <VBox alignment="CENTER" HBox.hgrow="ALWAYS">
               <children>
                  <ImageView fx:id="btnIndiceMultinivel" accessibleRole="BUTTON" fitHeight="120.0" fitWidth="140.0" onMouseClicked="#openIndiceMultinivel" pickOnBounds="true" preserveRatio="true">
                     <image>
                        <Image url="@/icono-b.externas.png" />
                     </image>
                     <cursor>
                        <Cursor fx:constant="HAND" />
                     </cursor>
                  </ImageView>
                  <Label text="MULTINIVEL">
                     <font>
                        <Font name="Myanmar Text Bold" size="18.0" />
                     </font>
                  </Label>
               </children>
            </VBox>
         </children>
      </HBox>
   </children>
</AnchorPane>
