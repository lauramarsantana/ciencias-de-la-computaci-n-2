<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="1280.0"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.ArbolesController">

   <stylesheets>
      <URL value="@styles.css" />
   </stylesheets>

   <children>

      <VBox spacing="20.0" layoutX="30.0" layoutY="20.0" prefWidth="1220.0" prefHeight="560.0">

         <children>

            <!-- Fila 1: Crear raíz -->
            <HBox spacing="15.0" alignment="CENTER_LEFT">
               <children>
                  <Label text="Raíz:">
                     <font>
                        <Font name="Myanmar Text Bold" size="20.0" />
                     </font>
                  </Label>

                  <TextField fx:id="raizField"
                             prefWidth="220.0"
                             promptText="Ingrese la raíz" />

                  <Button text="Crear raíz"
                          onAction="#crearRaiz"
                          prefWidth="120.0"
                          prefHeight="35.0" />
                  
                  <Button text="Guardar" onAction="#guardarArbol" />
                  <Button text="Cargar" onAction="#cargarArbol" />
                  
               </children>
            </HBox>

            <!-- Fila 2: Agregar relación -->
            <HBox spacing="15.0" alignment="CENTER_LEFT">
               <children>
                  <Label text="Padre:">
                     <font>
                        <Font name="Myanmar Text Bold" size="20.0" />
                     </font>
                  </Label>

                  <ComboBox fx:id="padreCombo"
                            prefWidth="180.0"
                            promptText="Seleccione padre" />

                  <Label text="Hijo:">
                     <font>
                        <Font name="Myanmar Text Bold" size="20.0" />
                     </font>
                  </Label>

                  <TextField fx:id="hijoField"
                             prefWidth="180.0"
                             promptText="Ingrese el hijo" />

                  <Button text="Agregar relación"
                          onAction="#agregarRelacion"
                          prefWidth="150.0"
                          prefHeight="35.0" />
                  
                  <Button text="Eliminar relación"
                         onAction="#eliminarRelacion"
                         prefWidth="150.0"
                         prefHeight="35.0" />

                  <Button text="Crear árbol"
                          onAction="#dibujarArbol"
                          prefWidth="140.0"
                          prefHeight="35.0" />

                  <Button text="Limpiar"
                          onAction="#limpiarArbol"
                          prefWidth="100.0"
                          prefHeight="35.0" />
                  
               </children>
            </HBox>

            <!-- Zona principal -->
            <HBox spacing="20.0" prefHeight="500.0" prefWidth="1220.0">

               <children>

                  <!-- Panel de dibujo -->
                  <VBox spacing="10.0">
                     <children>
                        <Label text="Visualización del árbol">
                           <font>
                              <Font name="Myanmar Text Bold" size="22.0" />
                           </font>
                        </Label>

                        <Pane fx:id="panelArbol"
                              prefHeight="450.0"
                              prefWidth="780.0"
                              style="-fx-background-color: white; -fx-border-color: black; -fx-border-width: 2;" />
                     </children>
                  </VBox>

                  <!-- Panel de información -->
                  <VBox spacing="10.0">
                     <children>
                        <Label text="Información del árbol">
                           <font>
                              <Font name="Myanmar Text Bold" size="22.0" />
                           </font>
                        </Label>

                        <TextArea fx:id="infoArea"
                                  prefHeight="450.0"
                                  prefWidth="400.0"
                                  wrapText="true"
                                  editable="false" />
                     </children>
                  </VBox>

               </children>
            </HBox>

         </children>

      </VBox>

   </children>
</AnchorPane>