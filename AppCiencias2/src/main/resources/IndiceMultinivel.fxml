<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="760.0" prefWidth="1280.0"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.IndiceMultinivelController">

    <stylesheets>
        <URL value="@/styles.css" />
    </stylesheets>

    <children>
        <VBox alignment="TOP_CENTER" prefHeight="760.0" prefWidth="1280.0"
              spacing="14" style="-fx-background-color: #fff;">
            <padding>
                <Insets top="16" right="16" bottom="16" left="16"/>
            </padding>

            <children>

                <!-- Configuración -->
                <HBox alignment="CENTER" spacing="10">
                    <children>
                        <Label text="Tipo:" />
                        <ChoiceBox fx:id="tipoIndiceChoice" prefWidth="120.0" />

                        <Label text="Registros (r):" />
                        <TextField fx:id="registrosField" prefWidth="80" promptText="30000"/>

                        <Label text="Bloque (B):" />
                        <TextField fx:id="bloqueField" prefWidth="80" promptText="1024"/>

                        <Label text="Registro dato (R):" />
                        <TextField fx:id="registroDatoField" prefWidth="80" promptText="100"/>

                        <Label text="Registro índice (Ri):" />
                        <TextField fx:id="registroIndiceField" prefWidth="80" promptText="15"/>

                        <Button text="Crear estructura" onAction="#crearEstructura"/>
                    </children>
                </HBox>

                <!-- Resultados -->
                <VBox spacing="6"
                      style="-fx-border-color: #0e2ebe; -fx-border-width: 1; -fx-padding: 10; -fx-background-color: #f8faff;">
                    <children>
                        <Label fx:id="bfrLabel" text="Registros por bloque de datos (bfr) = " />
                        <Label fx:id="bLabel" text="Bloques de datos necesarios (b) = " />
                        <Label fx:id="bfriLabel" text="Entradas de índice por bloque (bfri) = " />
                        <Label fx:id="nivel1Label" text="Bloques de índice nivel 1 = " />
                        <Label fx:id="nivel2Label" text="Bloques de índice nivel 2 = " />
                        <Label fx:id="nivel3Label" text="Bloques de índice nivel 3 = " />
                        <Label fx:id="accesosLabel" text="Accesos con índice multinivel = " />
                    </children>
                </VBox>

                <!-- Explicación -->
                <HBox alignment="CENTER">
                    <children>
                        <Label fx:id="explicacionLabel"
                               wrapText="true"
                               prefWidth="1100"
                               maxWidth="1100"
                               style="-fx-font-size: 14px; -fx-text-fill: #333333;" />
                    </children>
                </HBox>

                <!-- Estructura visual -->
                <HBox alignment="TOP_CENTER" spacing="30">
                    <children>

                        <!-- Índices externos -->
                        <VBox spacing="8" alignment="TOP_CENTER">
                            <children>
                                <Label text="ÍNDICES EXTERNOS"
                                       style="-fx-font-weight: bold; -fx-font-size: 16px;" />
                                <VBox fx:id="externosBox"
                                      prefWidth="220"
                                      prefHeight="260"
                                      spacing="8"
                                      style="-fx-border-color: black; -fx-padding: 8;" />
                            </children>
                        </VBox>

                        <!-- Índices internos -->
                        <VBox spacing="8" alignment="TOP_CENTER">
                            <children>
                                <Label text="ÍNDICES INTERNOS"
                                       style="-fx-font-weight: bold; -fx-font-size: 16px;" />
                                <VBox fx:id="internosBox"
                                      prefWidth="280"
                                      prefHeight="260"
                                      spacing="8"
                                      style="-fx-border-color: black; -fx-padding: 8;" />
                            </children>
                        </VBox>

                        <!-- Estructura de datos -->
                        <VBox spacing="8" alignment="TOP_CENTER">
                            <children>
                                <Label text="ESTRUCTURA DE DATOS"
                                       style="-fx-font-weight: bold; -fx-font-size: 16px;" />
                                <VBox fx:id="datosBox"
                                      prefWidth="340"
                                      prefHeight="260"
                                      spacing="8"
                                      style="-fx-border-color: black; -fx-padding: 8;" />
                            </children>
                        </VBox>

                    </children>
                </HBox>

                <!-- Botones -->
                <HBox alignment="CENTER" spacing="20">
                    <children>
                        <Button text="Limpiar" onAction="#limpiarEstructura"/>
                        <Button text="Guardar Estructura" onAction="#guardarEstructura"/>
                        <Button text="Recuperar Estructura" onAction="#cargarEstructura"/>
                    </children>
                </HBox>

                <!-- Resultado -->
                <Label fx:id="resultadoLabel"
                       text="Listo."
                       textFill="#0e2ebe">
                    <font>
                        <Font name="Myanmar Text Bold" size="20.0" />
                    </font>
                </Label>

            </children>
        </VBox>
    </children>
</AnchorPane>
