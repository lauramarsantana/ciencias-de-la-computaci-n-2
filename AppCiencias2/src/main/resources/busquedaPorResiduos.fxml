<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane fx:id="residuosPane" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.BPorResiduosController">
   <stylesheets>
      <URL value="@styles.css" />
   </stylesheets>
   <children>
      <HBox alignment="CENTER" prefWidth="1280.0">
         <children>
            <VBox alignment="CENTER" prefHeight="600.0" HBox.hgrow="ALWAYS">
               <children>
                  <ImageView accessibleRole="BUTTON" fitHeight="150.0" fitWidth="200.0" onMouseClicked="#openArbolDigital" pickOnBounds="true" preserveRatio="true">
                     <image>
                        <Image url="@icono-B.porResiduos.png" />
                     </image>
                     <cursor>
                        <Cursor fx:constant="HAND" />
                     </cursor>
                  </ImageView>
                  <Label text="B. arboles digitales">
                     <font>
                        <Font name="Myanmar Text Bold" size="24.0" />
                     </font>
                  </Label>
               </children>
            </VBox>
            <VBox alignment="CENTER" prefHeight="600.0" HBox.hgrow="ALWAYS">
               <children>
                  <ImageView accessibleRole="BUTTON" fitHeight="150.0" fitWidth="200.0" onMouseClicked="#openTries" pickOnBounds="true" preserveRatio="true">
                     <image>
                        <Image url="@icono-B.porResiduos.png" />
                     </image>
                     <cursor>
                        <Cursor fx:constant="HAND" />
                     </cursor>
                  </ImageView>
                  <Label text="Tries por residuos">
                     <font>
                        <Font name="Myanmar Text Bold" size="24.0" />
                     </font>
                  </Label>
               </children>
            </VBox>
            <VBox alignment="CENTER" prefHeight="600.0" HBox.hgrow="ALWAYS">
               <children>
                  <ImageView accessibleRole="BUTTON" fitHeight="150.0" fitWidth="200.0" onMouseClicked="#openResiduosMultiples" pickOnBounds="true" preserveRatio="true">
                     <image>
                        <Image url="@icono-B.porResiduos.png" />
                     </image>
                     <cursor>
                        <Cursor fx:constant="HAND" />
                     </cursor>
                  </ImageView>
                  <Label text="B. por residuos multiples">
                     <font>
                        <Font name="Myanmar Text Bold" size="24.0" />
                     </font>
                  </Label>
               </children>
            </VBox>
            <VBox alignment="CENTER" prefHeight="600.0" HBox.hgrow="ALWAYS">
               <children>
                  <ImageView accessibleRole="BUTTON" fitHeight="150.0" fitWidth="200.0" onMouseClicked="#openHuffman" pickOnBounds="true" preserveRatio="true">
                     <image>
                        <Image url="@icono-B.porResiduos.png" />
                     </image>
                     <cursor>
                        <Cursor fx:constant="HAND" />
                     </cursor>
                  </ImageView>
                  <Label text="Arbol de Huffman">
                     <font>
                        <Font name="Myanmar Text Bold" size="24.0" />
                     </font>
                  </Label>
               </children>
            </VBox>
         </children>
      </HBox>
   </children>
</AnchorPane>
