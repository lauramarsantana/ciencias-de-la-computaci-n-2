<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.geometry.Rectangle2D?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane fx:id="contentPane" prefHeight="500.0" prefWidth="700.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.InicioController">
    <!--agregar la hoja de estilos-->
    <stylesheets>
        <URL value="@styles.css" />
    </stylesheets>
    <children>
        <BorderPane prefHeight="500.0" prefWidth="700.0">

         <top>
            <VBox alignment="CENTER" style="-fx-background-color: #2262C6;" BorderPane.alignment="CENTER">
               <children>
                  <HBox alignment="CENTER_LEFT" nodeOrientation="LEFT_TO_RIGHT" BorderPane.alignment="CENTER">
                     <children>
                        <ImageView fx:id="btnMenu" accessibleRole="BUTTON" fitWidth="30.0" nodeOrientation="RIGHT_TO_LEFT" onMouseClicked="#openMenu" pickOnBounds="true" preserveRatio="true">
                           <image>
                              <Image url="@icno-hambuguerMenu.png" />
                           </image>
                           <cursor>
                              <Cursor fx:constant="HAND" />
                           </cursor>
                           <HBox.margin>
                              <Insets left="20.0" right="120.0" />
                           </HBox.margin>
                        </ImageView>
                        <ImageView fitHeight="150.0" fitWidth="300.0" pickOnBounds="true" preserveRatio="true">
                           <image>
                              <Image url="@logo-CienciasII.png" />
                           </image>
                           <viewport>
                              <Rectangle2D />
                           </viewport>
                           <HBox.margin>
                              <Insets />
                           </HBox.margin>
                        </ImageView>
                     </children>
                  </HBox>
               </children>
            </VBox>
         </top>
         <center>
            <HBox alignment="CENTER" BorderPane.alignment="CENTER">
               <children>
                  <VBox accessibleRole="BUTTON" alignment="CENTER" HBox.hgrow="ALWAYS">
                     <children>
                        <ImageView fx:id="btnBusquedas" accessibleRole="BUTTON" fitHeight="150.0" fitWidth="200.0" onMouseClicked="#openBusquedas" pickOnBounds="true" preserveRatio="true">
                           <image>
                              <Image url="@icono-busquedas.png" />
                           </image>
                           <cursor>
                              <Cursor fx:constant="HAND" />
                           </cursor>
                        </ImageView>
                        <Label text="BUSQUEDAS" textFill="#000204">
                           <font>
                              <Font name="Myanmar Text Bold" size="24.0" />
                           </font>
                        </Label>
                     </children>
                     <cursor>
                        <Cursor fx:constant="HAND" />
                     </cursor>
                  </VBox>
                  <VBox alignment="CENTER" HBox.hgrow="ALWAYS">
                     <children>
                        <ImageView fx:id="btnGrafos" accessibleRole="BUTTON" fitHeight="150.0" fitWidth="200.0" onMouseClicked="#openGrafos" pickOnBounds="true" preserveRatio="true">
                           <image>
                              <Image url="@icono-grafos.png" />
                           </image>
                           <cursor>
                              <Cursor fx:constant="HAND" />
                           </cursor>
                        </ImageView>
                        <Label text="GRAFOS">
                           <font>
                              <Font name="Myanmar Text Bold" size="24.0" />
                           </font>
                        </Label>
                     </children>
                  </VBox>
               </children>
               <padding>
                  <Insets bottom="40.0" top="40.0" />
               </padding>
            </HBox>
         </center>
        </BorderPane>
        <AnchorPane fx:id="menuContainer" />
    </children>
</AnchorPane>
