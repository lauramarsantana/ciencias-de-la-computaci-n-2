<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<AnchorPane xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.TriesResiduosController"
            prefWidth="1200" prefHeight="800">

    <children>
        <VBox spacing="12" alignment="CENTER" AnchorPane.topAnchor="10" AnchorPane.leftAnchor="10"
              AnchorPane.rightAnchor="10" AnchorPane.bottomAnchor="10">
            <padding>
                <Insets top="20" left="20" right="20" bottom="20"/>
            </padding>

            <HBox spacing="10" alignment="CENTER">
                <Label text="Mensaje:"/>
                <TextField fx:id="mensajeField" promptText="Ej: MURCIELAGO"/>
                <Button text="Procesar" onAction="#procesarMensaje"/>
                <Button text="Reiniciar" onAction="#initializeTree"/>
            </HBox>

            <HBox spacing="10" alignment="CENTER">
                <Label text="Buscar letra:"/>
                <TextField fx:id="buscarField" promptText="Ej: A"/>
                <Button text="Buscar" onAction="#buscarClave"/>
                <Button text="Limpiar búsqueda" onAction="#clearSearch"/>
            </HBox>

            <TableView fx:id="tablaCodigos" prefHeight="200" prefWidth="800">
                <columns>
                    <TableColumn fx:id